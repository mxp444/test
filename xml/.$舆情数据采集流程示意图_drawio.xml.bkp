        <mxCell id="2" value="需求分析阶段——舆情数据采集流程示意图" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=18;" vertex="1" parent="1"><mxGeometry x="360" y="20" width="760" height="42" as="geometry"/></mxCell><mxCell id="3" value="管理员负责采集任务配置与控制，普通用户主要查看采集和分析后的结果" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="360" y="68" width="760" height="28" as="geometry"/></mxCell><mxCell id="4" value="1. 管理员进入&#xa;后台采集任务管理模块" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#4A90E2;fillColor=#F5FAFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="5" value="2. 选择采集平台&#xa;微博 / 抖音 / 百度贴吧 / 小红书" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#6AA84F;fillColor=#F7FBF5;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="250" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="6" value="3. 配置采集规则&#xa;关键词 / Cookie 等" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#F5A623;fillColor=#FFF9F0;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="460" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="7" value="4. 提交采集任务&#xa;系统接收任务" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#8E67D6;fillColor=#FAF7FF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="670" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="8" value="5. 启动对应平台的&#xa;采集流程" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#61B8E5;fillColor=#F5FBFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="880" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="9" value="6. 差异化采集策略&#xa;适配不同平台结构与入口" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#A8A8A8;fillColor=#FAFAFA;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1090" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="10" value="7. 内容解析&#xa;帖子正文 / 作者信息" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#E67E22;fillColor=#FFF8F0;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1300" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="11" value="8. 关键词过滤与去重&#xa;剔除无关和重复数据" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#3D7DDE;fillColor=#F5FAFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1510" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="12" value="9. 写入 MongoDB&#xa;对应集合" style="rounded=1;arcSize=12;strokeWidth=2;shadow=0;whiteSpace=wrap;html=1;strokeColor=#9B59B6;fillColor=#FBF7FF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1720" y="180" width="170" height="90" as="geometry"/></mxCell><mxCell id="13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#000000;" edge="1" parent="1" source="4" target="5