adow=0;whiteSpace=wrap;html=1;strokeColor=#8B5BD1;fillColor=#FAF7FF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="815" y="360" width="260" height="100" as="geometry"/></mxCell><mxCell id="22" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#000000;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="12" target="21"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" value="" style="rounded=1;arcSize=10;strokeWidth=2;dashed=1;dashPattern=8 8;shadow=0;fillColor=none;whiteSpace=wrap;html=1;strokeColor=#4A90E2;" vertex="1" parent="1"><mxGeometry x="40" y="520" width="620" height="200" as="geometry"/></mxCell><mxCell id="24" value="管理员后台功能" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontColor=#2F63B8;" vertex="1" parent="1"><mxGeometry x="60" y="540" width="180" height="28" as="geometry"/></mxCell><mxCell id="25" value="配置采集平台和规则" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#4A90E2;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="75" y="585" width="240" height="42" as="geometry"/></mxCell><mxCell id="26" value="控制采集任务启动" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#4A90E2;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="75" y="637" width="240" height="42" as="geometry"/></mxCell><mxCell id="27" value="查看采集状态与结果" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#4A90E2;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="75" y="689" width="240" height="42" as="geometry"/></mxCell><mxCell id="28" value="说明：采集任务控制属于管理员后台功能。" style="rounded=1;arcSize=8;strokeWidth=1.5;strokeColor=#4A90E2;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="335" y="585" width="300" height="94" as="geometry"/></mxCell><mxCell id="29" value="" style="rounded=1;arcSize=10;strokeWidth=2;dashed=1;dashPattern=8 8;shadow=0;fillColor=none;whiteSpace=wrap;html=1;strokeColor=#6AA84F;" vertex="1" parent="1"><mxGeometry x="1260" y="520" width="620" height="200" as="geometry"/></mxCell><mxCell id="30" value="普通用户前台功能" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontColor=#3F8F2D;" vertex="1" parent="1"><mxGeometry x="1280" y="540" width="180" height="28" as="geometry"/></mxCell><mxCell id="31" value="查看已采集并分析后的舆情结果" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#6AA84F;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1295" y="590" width="250" height="48" as="geometry"/></mxCell><mxCell id="32" value="不直接参与采集任务配置与控制" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#6AA84F;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1295" y="648" width="250" height="48" as="geometry"/></mxCell><mxCell id="33" value="说明：原始舆情数据写入数据库后，不直接作为最终风险结论，&#xa;而是继续进入后续文本、图像等分析流程。" style="rounded=1;arcSize=8;strokeWidth=1.5;strokeColor=#6AA84F;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1560" y="585" width="295" height="110" as="geometry"/></mxCell><mxCell id="34" value="" style="rounded=1;arcSize=10;strokeWidth=2;dashed=1;dashPattern=8 8;shadow=0;fillColor=none;whiteSpace=wrap;html=1;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="680" y="520" width="540" height="200" as="geometry"/></mxCell><mxCell id="35" value="流程要点" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="700" y="540" width="120" height="28" as="geometry"/></mxCell><mxCell id="36" value="不同平台采用差异化采集策略" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#B3B3B3;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="715" y="585" width="470" height="38" as="geometry"/></mxCell><mxCell id="37" value="采集后先解析，再过滤与去重" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#B3B3B3;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="715" y="633" width="470" height="38" as="geometry"/></mxCell><mxCell id="38" value="数据最终存入 MongoDB 对应集合" style="rounded=1;arcSize=10;strokeWidth=1.5;shadow=0;fillColor=#FFFFFF;whiteSpace=wrap;html=1;strokeColor=#B3B3B3;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="715" y="681" width="470" height="38" as="geometry"/></mxCell>
