        <mxCell id="2" value="图像内容检测子模块工作流程" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="115" y="12" width="360" height="30" as="geometry"/></mxCell><mxCell id="3" value="帖子配图 / 图片路径" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="25" y="85" width="130" height="48" as="geometry"/></mxCell><mxCell id="4" value="图像读取与预处理&#xa;读取 / 解码 / 尺寸转换&#xa;颜色空间转换" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="25" y="170" width="130" height="78" as="geometry"/></mxCell><mxCell id="5" value="" style="rounded=1;arcSize=8;strokeWidth=1.2;dashed=1;dashPattern=6 6;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=none;" vertex="1" parent="1"><mxGeometry x="180" y="60" width="255" height="510" as="geometry"/></mxCell><mxCell id="6" value="五类图像检测子模块" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="205" y="72" width="205" height="24" as="geometry"/></mxCell><mxCell id="7" value="OCR 文字识别&#xa;启动 OCR → 提交任务 → 回调结果&#xa;输出：文字内容 / 位置信息" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="200" y="110" width="215" height="68" as="geometry"/></mxCell><mxCell id="8" value="二维码检测&#xa;灰度 / 滤波 / 二值化 → OpenCV 检测&#xa;输出：是否存在二维码 / 内容 / 位置" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="200" y="190" width="215" height="68" as="geometry"/></mxCell><mxCell id="9" value="模糊度检测&#xa;缩放 / 灰度化 → 拉普拉斯边缘&#xa;输出：边缘强度分数" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="200" y="270" width="215" height="68" as="geometry"/></mxCell><mxCell id="10" value="色彩丰富程度评估&#xa;HSV 转换 → 色相 / 亮度 / 对比度计算&#xa;输出：综合质量分数" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="200" y="350" width="215" height="68" as="geometry"/></mxCell><mxCell id="11" value="设计感评估&#xa;MobileNet 预处理 → 模型预测&#xa;输出：美学平均分 / 标准差" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="200" y="430" width="215" height="68" as="geometry"/></mxCell><mxCell id="12" value="图像侧风险特征汇总&#xa;OCR 文本 / 二维码结果&#xa;清晰度 / 色彩分数 / 设计感分数" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="460" y="175" width="110" height="110" as="geometry"/></mxCell><mxCell id="13" value="输出至&#xa;多模态融合分析" style="rounded=1;arcSize=8;strokeWidth=1.4;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;"