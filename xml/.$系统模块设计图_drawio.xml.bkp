        <mxCell id="2" value="系统模块设计图" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="185" y="15" width="220" height="28" as="geometry"/></mxCell><mxCell id="3" value="核心流程：数据采集 → 数据存储 → 风险分析 → 结果展示" style="text;strokeColor=none;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="110" y="45" width="370" height="22" as="geometry"/></mxCell><mxCell id="4" value="用户 / 浏览器&#xa;普通用户、管理员" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="185" y="80" width="220" height="56" as="geometry"/></mxCell><mxCell id="5" value="前端页面模块&#xa;监测首页、舆情监测、风险分析、详情报告、后台页面" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="95" y="165" width="400" height="66" as="geometry"/></mxCell><mxCell id="6" value="后端接口模块&#xa;Flask：登录权限、数据查询、采集调度、分析调度、平台配置、账号管理、系统设置" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="65" y="255" width="460" height="74" as="geometry"/></mxCell><mxCell id="7" value="多元舆情采集模块&#xa;微博、抖音、百度贴吧、小红书&#xa;关键词检索、帖子解析、图片下载、过滤去重" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="30" y="365" width="240" height="88" as="geometry"/></mxCell><mxCell id="8" value="MongoDB 数据库模块&#xa;统一字段结构&#xa;按平台分集合保存舆情数据与分析结果" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="175" y="485" width="240" height="80" as="geometry"/></mxCell><mxCell id="9" value="文本风险识别模块&#xa;正文与 OCR 文本分析&#xa;识别金融属性、风险要素、情感倾向、煽动性" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="320" y="365" width="240" height="88" as="geometry"/></mxCell><mxCell id="10" value="图像内容检测模块&#xa;二维码检测、模糊度、色彩丰富度&#xa;设计感评估、OCR 文字提取" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="320" y="585" width="240" height="88" as="geometry"/></mxCell><mxCell id="11" value="多模态融合风险评估模块&#xa;融合正文、图片、OCR 文本&#xa;输出风险分、风险等级、风险原因、处置建议" style="rounded=1;arcSize=8;strokeWidth=1.5;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="95" y="705" width="400" height="88" as="geometry"/></mxCell><mxCell id="12" value="结果回写数据库，并作为前端展示与详情报告的数据来源" style="rounded=1;arcSize=8;strokeWidth=1.2;dashed=1;dashPattern=6 6;shadow=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=none;fontFamily=宋体;fontSize=15;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="95" y="825" width="400" height="48" as="geometry"/></mxCell><mxCell id="13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;end